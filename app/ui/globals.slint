export struct PathSegment {
    label: string,    // visible name; "/" for root
    full-path: string, // absolute path navigated to on click
}

export struct TabInfo {
    title: string,
    is-active: bool,
    // Folder this tab is showing; "" for non-local. Drop target for DnD.
    path: string,
}

// ─── AppState — view state pushed by Rust ───────────────────────────────
export global AppState {
    in-out property <string> current-path: "/";
    /// Human-readable summary of the current selection for the status bar's
    /// left side (e.g. `3 folders selected (12 direct items), 2 files (5 MB)`).
    /// Empty when nothing is selected, so the bar falls back to the item count.
    in-out property <string> selection-summary: "";
    /// Bumped on every click inside the file views; the main FocusScope watches
    /// it and reclaims keyboard focus (the grid's ScrollView would otherwise
    /// keep it and swallow global shortcuts like Delete).
    in-out property <int> focus-nonce: 0;
    in-out property <[PathSegment]> path-segments: [];
    in-out property <bool> can-go-back: false;
    in-out property <bool> can-go-forward: false;
    in-out property <bool> can-go-up: false;
    in-out property <bool> loading: false;
    in-out property <string> status-text: "";
    in-out property <string> error-text: "";
    /// Pre-formatted "X GB free of Y GB" for the bottom bar — Rust refreshes
    /// it whenever the current directory changes. Empty hides the indicator.
    in-out property <string> disk-free-text: "";
    /// Bumped by Rust after a keyboard navigation; FileListView watches this
    /// and scrolls the target row into view.
    in-out property <int> scroll-to-row: -1;
    /// Live Ctrl-pressed flag tracked by the top-level FocusScope. Workaround
    /// for Slint 1.16 issue #6263 — wheel events from the winit backend don't
    /// carry the live modifier state, so scroll-event handlers must read this
    /// instead of `event.modifiers.control`.
    in-out property <bool> ctrl-held: false;
    /// True while the toolbar path-bar is in free-edit mode (LineEdit shown
    /// + focused). Exposed globally so the keyboard FocusScope can refocus
    /// once the user leaves edit mode — otherwise focus stays on the now-
    /// hidden LineEdit and every shortcut silently breaks.
    in-out property <bool> path-edit-active: false;
    /// True if the app is running as root (euid 0). Drives the warning
    /// banner across the top of the window.
    in-out property <bool> is-root: false;
    /// Mirror of MainWindow.selected-count so popups can read it without
    /// being prop-drilled.
    in-out property <int> selected-count: 0;
    /// Name of the default application for the currently-selected file
    /// (single-selection only). Empty when unknown / multi / no selection.
    in-out property <string> default-app-name: "";
    /// True when any selected entry is an extractable archive (zip/7z/rar/
    /// tar.*/gz/bz2/xz/zst). Drives the "Extract here" menu item.
    in-out property <bool> selection-has-archive: false;
    /// How many selected entries are directories. Drives the context-menu
    /// "Open in new tab" / "Open in new tabs" item.
    in-out property <int> selection-dir-count: 0;
    /// True while the current view is the Trash. Drives the Restore / Empty
    /// trash toolbar + context-menu actions.
    in-out property <bool> in-trash: false;
    /// The single selected directory is already a user bookmark. Drives the
    /// file context-menu "Add ↔ Remove bookmark" toggle.
    in-out property <bool> selection-is-bookmarked: false;
    /// The single selected directory can be bookmarked — it's a dir that isn't
    /// already reachable from Computer/Places (those are pointless to bookmark).
    in-out property <bool> selection-can-bookmark: false;
    /// The current folder is already a user bookmark. Drives the empty-area
    /// folder context-menu toggle.
    in-out property <bool> current-folder-is-bookmarked: false;
    /// The current folder can be bookmarked (local dir not already in
    /// Computer/Places).
    in-out property <bool> current-folder-can-bookmark: false;
}

// ─── Callabler — every "user did X" callback Rust should react to ──────
export global Callabler {
    callback navigate-to(string);
    callback navigate-back();
    callback navigate-forward();
    callback navigate-up();
    callback navigate-home();
    callback refresh();
    callback toggle-hidden();
    callback toggle-theme();
    callback toggle-auto-refresh();
    callback row-activated(int);
    /// Enter key on the current selection: navigate into a single folder,
    /// open a single file, or open all (with bulk-confirm) for multi.
    callback activate-selection();
    callback select-row(int, SelectMode);
    callback select-all();
    callback select-none();
    callback nav-selection(NavKey, bool);     // (key, shift-held)
    callback sort-by(SortKey);
    // Rubber-band selection: x1,y1,x2,y2 are pixel coords inside the grid origin.
    // tile-w/tile-h/cell-w/cols/gutter are needed for the Rust-side hit test.
    // Snapshot the selection when a rubber-band drag starts (for Ctrl toggle).
    callback rubberband-begin();
    // …, ctrl: last bool toggles intersected items against the snapshot instead
    // of replacing the selection.
    callback rubberband-select(float, float, float, float, float, float, float, int, float, bool);
    /// Step the item-size by ±1 (clamped 1..=7). Wired to Ctrl+wheel and the
    /// 7-step status-bar widget.
    callback cycle-item-size(int);
    /// Diagnostics for the Ctrl+wheel interaction. Slint 1.16's winit backend
    /// strips modifier state out of wheel events, so we track ctrl on a global
    /// updated by the top-level FocusScope's key handlers. This callback logs
    /// every wheel hit (with the current global ctrl flag) so users can pin
    /// down whether the issue is a missed key event, the wheel firing on a
    /// component that didn't reach this handler, or something else.
    callback debug-wheel(string, float, bool);
    /// Logged whenever the top-level FocusScope sees a key event — both press
    /// and release — so we can see when ctrl-held flips on/off.
    callback debug-ctrl-change(bool, string);

    // File operations
    callback clipboard-cut();
    callback clipboard-copy();
    // Copy the selected item path(s) to the system clipboard as text.
    callback copy-path();
    callback clipboard-paste();
    callback open-default-app();
    callback bulk-open-confirmed();
    callback move-to-trash();
    callback restore-from-trash();
    callback empty-trash();
    callback empty-trash-confirmed();

    // ── Remote (ssh/smb/ftp) mounting via GVFS ──
    callback remote-mount-confirmed(string);
    callback remote-mount-cancelled();
    callback request-rename();
    callback rename-confirmed(string);
    callback bulk-rename-preview(string);
    callback bulk-rename-apply(string);
    callback request-delete-permanently();
    callback delete-confirmed();

    // Sidebar / bookmarks
    callback place-clicked(string);
    /// Add or remove a bookmark for the single selected directory, depending on
    /// whether it's currently bookmarked.
    callback toggle-bookmark-of-selected();
    /// Add or remove a bookmark for the current folder (empty-area menu).
    callback toggle-bookmark-of-current();
    callback remove-bookmark(string);
    /// Search context-menu only: navigate to the parent folder of the (single)
    /// selected search hit, dropping search mode.
    callback open-containing-folder();

    // Properties
    callback request-properties();
    callback properties-closed();
    // Apply edited Unix permission bits (decimal value of the octal mode) to
    // the file shown in the Properties dialog.
    callback apply-permissions(int);

    // Search
    callback open-search();
    callback close-search();
    callback search-query-changed(string);

    // UDisks / removable devices
    callback devices-changed();
    callback mount-device(string);
    callback unmount-device(string);

    // New folder / file
    callback request-new-folder();
    callback new-folder-confirmed(string);
    callback create-empty-file();
    callback new-file-confirmed(string);

    // Current-folder properties (right-click on empty area)
    callback request-folder-properties();
    /// Spawn a terminal in `path` (selected folder or current dir).
    callback open-in-terminal(string);
    /// Spawn a new instance of this app as root, browsing `path`.
    callback open-as-root(string);

    // Archive extraction
    /// "Extract here" right-click target. Operates on whatever is selected.
    callback extract-selected();
    /// User submitted a password from the prompt — retry the current archive.
    callback extract-password-confirmed(string);
    /// User dismissed the prompt — abandon the remaining queue.
    callback extract-cancelled();

    // Settings panel: switches change Settings directly; these no-op callbacks
    // exist so glue code can react (e.g. attach/detach watcher).
    callback toggle-hidden-noop();
    callback toggle-watcher-noop();
    // Thumbnail resolution changed in settings → re-generate for current view.
    callback thumb-size-changed(int);
    // Thumbnail memory budget changed in settings (value in MiB) → update the
    // live cap and re-generate so freshly-allowed rows fill in.
    callback thumb-mem-budget-changed(int);

    // Tabs
    callback new-tab();
    callback close-tab(int);
    callback switch-tab(int);
    // Open the single selected folder in a new tab of the active pane.
    callback open-in-new-tab();
    // Pane-aware tab ops used by the per-pane tab strips. `is-right` is the
    // physical side of the strip; the handler focuses that pane (swapping the
    // active pane if needed) before acting on it.
    callback tab-new-in(bool /* is-right */);
    callback tab-close-in(bool /* is-right */, int /* idx */);
    callback tab-switch-in(bool /* is-right */, int /* idx */);

    // Split view
    callback toggle-split();
    callback swap-active-pane();

    // Undo / redo (Ctrl+Z / Ctrl+Y) of reversible file operations.
    callback undo();
    callback redo();

    // Internal drag-and-drop. start-drag passes the pressed row index (active
    // pane); drop-dragged passes whether Ctrl was held (copy instead of move).
    callback start-drag(int);
    callback drop-dragged(bool);
    callback cancel-drag();

    // Open-with picker. request-open-with builds the app list for the current
    // selection; open-with-chosen launches the picked .desktop id (set-default
    // = also persist it as the default for the file type).
    callback request-open-with();
    callback open-with-chosen(string, bool);
    // Run a typed command on the selection; bool = remember it in the list.
    callback open-with-command(string, bool);

    // Create an archive from the selection. compress-confirmed(name, format, pw)
    // where format: 0=zip, 1=7z, 2=tar.gz.
    callback request-compress();
    callback compress-confirmed(string, int, string);
    // Resolve a copy/move conflict. First arg: 0=replace, 1=skip, 2=keep-both,
    // 3=cancel. Second arg: apply to all remaining conflicts.
    callback conflict-chosen(int, bool);
}

// ─── DialogState — drives the modal popup overlays ──────────────────────
export global DialogState {
    in-out property <bool> delete-confirm-open: false;
    in-out property <bool> rename-open: false;
    in-out property <bool> properties-open: false;
    in-out property <bool> new-folder-open: false;
    in-out property <bool> new-file-open: false;
    in-out property <bool> bulk-rename-open: false;
    in-out property <bool> empty-trash-confirm-open: false;
    in-out property <bool> remote-mount-open: false;
    in-out property <string> remote-host: "";
    in-out property <bool> remote-error: false;
    in-out property <bool> nav-error-open: false;
    in-out property <bool> open-with-open: false;
    // Human-readable file type shown as the dialog subtitle (e.g. "text/plain").
    in-out property <string> open-with-subtitle: "";
    in-out property <bool> compress-open: false;
    in-out property <string> compress-default-name: "archive";
    in-out property <string> rename-initial: "";
    in-out property <string> new-file-initial: "untitled.txt";
    in-out property <string> nav-error-message: "";
    // Empty → use the default "Cannot open this location" title; non-empty
    // overrides it (e.g. copy/move failure summaries reuse this dialog).
    in-out property <string> nav-error-title: "";
    in-out property <string> bulk-rename-pattern: "{name}_{2:idx}{ext.}";
    in-out property <int> delete-target-count: 0;
    in-out property <int> bulk-rename-conflicts: 0;
    in-out property <bool> bulk-open-confirm-open: false;
    in-out property <int> bulk-open-count: 0;
    // Archive extraction password prompt.
    in-out property <bool> extract-password-open: false;
    /// Basename of the archive currently being extracted (shown in the prompt).
    in-out property <string> extract-archive-name: "";
    /// Last error from a previous attempt (empty on first prompt).
    in-out property <string> extract-error: "";
    // Copy/move conflict prompt (destination already exists).
    in-out property <bool> conflict-open: false;
    /// Basename of the conflicting item (shown in the prompt).
    in-out property <string> conflict-name: "";
    /// Bound to the "apply to all" checkbox; passed back on the chosen action.
    in-out property <bool> conflict-apply-all: false;
}

// ─── ProgressDialogCallbacks ─────────────────────────────────────────────
export global ProgressDialogCallbacks {
    callback cancel-requested();
    // Toggle pause; argument is the requested paused state.
    callback pause-requested(bool);
}

// ─── SearchState — toggled by Ctrl+F, drives results model in Rust ──────
export global SearchState {
    in-out property <bool> active: false;
    in-out property <string> query: "";
    in-out property <bool> searching: false;
    in-out property <int> result-count: 0;
}

// ─── DragState — internal drag-and-drop of file rows/tiles ──────────────
// The source row keeps the pointer grab while dragging, so it writes the live
// cursor position (window coords) here; every visible row reads it to decide
// whether the cursor is over it (a drop target), with no hover events needed.
export global DragState {
    in-out property <bool> active: false;
    in-out property <length> cursor-x;
    in-out property <length> cursor-y;
    // Ghost contents.
    in-out property <string> label;
    in-out property <string> icon: "file-generic";
    in-out property <int> count: 0;
    // Drop target: set by whichever folder the cursor currently contains.
    in-out property <bool> has-target: false;
    // Path-based target (sidebar place / tab). Non-empty takes precedence over
    // the index-based file-row target below.
    in-out property <string> target-path: "";
    in-out property <int> target-row: -1;
    in-out property <bool> target-active-pane: true;
}
