// Globals: Settings, ColorPalette, Translations, AppState, Callabler.
// All UI-side string/color/state lives here so it's swappable from Rust.

export enum AppViewMode {
    list,
    gallery,
}

export enum SortKey {
    name,
    size,
    mtime,
    kind,
}

export enum SortOrder {
    ascending,
    descending,
}

export enum SelectMode {
    single,    // plain click: clear and select this row
    toggle,    // Ctrl+click: toggle membership
    range,     // Shift+click: select from anchor to this row
}

export enum NavKey {
    up, down, page-up, page-down, home, end,
}

// File/folder icon set: flat monochrome line-art (theme-tinted) vs. full-colour.
export enum IconStyle {
    mono, color,
}

// ─── Theme settings ──────────────────────────────────────────────────────
export global Settings {
    in-out property <bool> dark-theme: true;
    in-out property <AppViewMode> view-mode: AppViewMode.list;
    /// Discrete element-size step shared by list + gallery (1=tiny … 7=huge).
    /// Independent of view-mode so the user can crank up icon size in list too.
    in-out property <int> item-size: 3;
    in-out property <bool> show-hidden: false;
    in-out property <SortKey> sort-key: SortKey.name;
    in-out property <SortOrder> sort-order: SortOrder.ascending;
    in-out property <bool> auto-refresh: false;
    in-out property <length> sidebar-width: 220px;
    /// Fraction of pane area allocated to the LEFT pane when split-view is on.
    in-out property <float> split-ratio: 0.5;
    /// Generated-thumbnail resolution: 0=Normal(128) 1=Large(256)
    /// 2=X-Large(512) 3=XX-Large(1024). Default matches the previous hard-coded
    /// X-Large.
    in-out property <int> thumb-size: 2;
    in-out property <IconStyle> icon-style: IconStyle.mono;
    // List-view column visibility (Name is always shown). Toggled from the
    // header right-click menu, persisted across sessions.
    in-out property <bool> col-size-visible: true;
    in-out property <bool> col-modified-visible: true;
    in-out property <bool> col-kind-visible: true;
    /// Max RAM (MiB) held by loaded thumbnails before new images stop loading.
    /// 0 = unlimited. Guards against huge image folders exhausting memory.
    in-out property <int> thumb-mem-budget-mb: 2048;
}

// ─── Color palette — every visible color in the app goes here ───────────
export global ColorPalette {
    out property <color> bg-window: Settings.dark-theme ? #1e1e1e : #f7f7f7;
    out property <color> bg-panel: Settings.dark-theme ? #252525 : #ffffff;
    out property <color> bg-sidebar: Settings.dark-theme ? #1a1a1a : #f0f0f0;
    out property <color> bg-row-even: Settings.dark-theme ? #232323 : #fafafa;
    out property <color> bg-row-odd: Settings.dark-theme ? #1e1e1e : #ffffff;
    out property <color> bg-row-hover: Settings.dark-theme ? #2f2f2f : #e8eef7;
    out property <color> bg-row-selected: Settings.dark-theme ? #2a4a7a : #cfe1ff;
    out property <color> bg-row-selected-hover: Settings.dark-theme ? #335fa0 : #b8d2ff;

    out property <color> text-primary: Settings.dark-theme ? #ececec : #1a1a1a;
    out property <color> text-secondary: Settings.dark-theme ? #a0a0a0 : #555555;
    out property <color> text-on-selected: Settings.dark-theme ? #ffffff : #0a2050;

    out property <color> border-subtle: Settings.dark-theme ? #333333 : #d8d8d8;
    out property <color> accent: #2f7ed8;
    out property <color> accent-hover: #4a93e8;

    out property <color> icon-tint: Settings.dark-theme ? #d0d0d0 : #404040;
    out property <color> icon-tint-selected: Settings.dark-theme ? #ffffff : #0a2050;
    out property <color> icon-accent: #2f7ed8;

    public pure function row-bg(idx: int, hovered: bool, selected: bool) -> color {
        if selected {
            return hovered ? self.bg-row-selected-hover : self.bg-row-selected;
        }
        if hovered {
            return self.bg-row-hover;
        }
        return mod(idx, 2) == 0 ? self.bg-row-even : self.bg-row-odd;
    }
}

