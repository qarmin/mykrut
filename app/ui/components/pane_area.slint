// One column of the (potentially) split view. Wraps the list/grid view-mode
// dispatch + a "this pane is active" accent border + an optional path label
// (used only when this pane is the inactive one, to remind the user what they
// are looking at).

import { ColorPalette, Settings, AppState, AppViewMode, SearchState, Callabler, TabInfo, DragState } from "../globals.slint";
import { FileRowData } from "structs.slint";
import { FileListView } from "file_list_view.slint";
import { FileGridView } from "file_grid_view.slint";
import { TabStrip } from "tab_strip.slint";
import { TrashBar } from "trash_bar.slint";

export component PaneArea inherits Rectangle {
    in property <[FileRowData]> rows;
    in property <[FileRowData]> search-rows;
    in property <bool> is-active;
    /// This pane is the one currently displaying the search overlay. Pinned to
    /// the pane search was started in — does NOT move with focus.
    in property <bool> showing-search;
    in property <bool> show-path-label;
    in property <string> path-label: "";

    // This pane's own tab list + its physical side.
    in property <[TabInfo]> tabs;
    in property <bool> is-right;

    in property <bool> has-selection;
    in property <bool> single-selection;
    in property <bool> selection-is-dir;
    in property <bool> clipboard-has-items;
    in property <bool> selection-in-trash;
    in property <bool> in-trash;

    background: ColorPalette.bg-panel;
    border-color: is-active ? ColorPalette.accent : ColorPalette.border-subtle;
    border-width: is-active ? 2px : 1px;
    border-radius: 4px;
    clip: true;

    VerticalLayout {
        spacing: 0;

        TabStrip {
            tabs: root.tabs;
            is-right: root.is-right;
        }

        if show-path-label: label-bar := Rectangle {
            height: 22px;
            // Dropping a drag onto this bar targets THIS pane's folder. The drag
            // source holds the pointer grab, so (like file rows) we can't rely on
            // hover — we poll the live cursor against our window rect instead.
            property <bool> drop-here:
                DragState.active
                && DragState.cursor-x >= self.absolute-position.x
                && DragState.cursor-x < self.absolute-position.x + self.width
                && DragState.cursor-y >= self.absolute-position.y
                && DragState.cursor-y < self.absolute-position.y + self.height;
            changed drop-here => {
                if (drop-here) {
                    DragState.has-target = true;
                    DragState.target-row = -1;
                    DragState.target-path = root.path-label;
                    DragState.target-active-pane = root.is-active;
                } else if (DragState.target-path == root.path-label) {
                    DragState.has-target = false;
                    DragState.target-path = "";
                }
            }
            background: drop-here
                ? ColorPalette.accent
                : (is-active ? ColorPalette.bg-row-selected : ColorPalette.bg-sidebar);
            Text {
                x: 8px;
                width: parent.width - 16px;
                text: path-label;
                color: is-active ? ColorPalette.text-on-selected : ColorPalette.text-secondary;
                vertical-alignment: center;
                font-size: 11px;
                font-weight: is-active ? 600 : 400;
                overflow: elide;
            }
            // Clicking the label of an inactive pane activates it (cheap entry
            // point for keyboard users who don't want to click into the list).
            if !is-active: TouchArea {
                clicked => { Callabler.swap-active-pane(); }
            }
        }

        if in-trash: TrashBar {}

        Rectangle {
            vertical-stretch: 1;

            // Search results appear on whichever pane owns the search overlay
            // (pinned at search-open time), regardless of which pane has focus.
            property <[FileRowData]> visible-rows:
                root.showing-search ? root.search-rows : root.rows;

            // Map item-size step (1..7) → concrete dimensions. Tables live here
            // so both views share the same scale.
            property <int> step: clamp(Settings.item-size, 1, 7);

            property <length> gallery-tile-w:
                  step == 1 ?  80px
                : step == 2 ? 110px
                : step == 3 ? 140px
                : step == 4 ? 180px
                : step == 5 ? 230px
                : step == 6 ? 320px
                :             440px;
            // Heights leave room for TWO lines of label plus a little bottom
            // breathing space under the second line (the text well is
            // tile-h - icon - paddings; at the smaller steps it was barely one
            // and a half lines, so the wrapped 2nd line hugged the edge).
            property <length> gallery-tile-h:
                  step == 1 ? 116px
                : step == 2 ? 148px
                : step == 3 ? 176px
                : step == 4 ? 212px
                : step == 5 ? 268px
                : step == 6 ? 360px
                :             492px;
            // ~80% of the tile width so the icon/thumbnail fills the tile
            // instead of floating in the middle of it.
            property <length> gallery-icon:
                  step == 1 ?  64px
                : step == 2 ?  90px
                : step == 3 ? 116px
                : step == 4 ? 148px
                : step == 5 ? 188px
                : step == 6 ? 264px
                :             364px;

            property <length> list-row-h:
                  step == 1 ? 20px
                : step == 2 ? 22px
                : step == 3 ? 26px
                : step == 4 ? 32px
                : step == 5 ? 42px
                : step == 6 ? 60px
                :             88px;
            property <length> list-icon:
                  step == 1 ? 14px
                : step == 2 ? 16px
                : step == 3 ? 18px
                : step == 4 ? 22px
                : step == 5 ? 30px
                : step == 6 ? 44px
                :             64px;

            if Settings.view-mode == AppViewMode.list: FileListView {
                width: 100%; height: 100%;
                rows: parent.visible-rows;
                showing-search: root.showing-search;
                is-active-pane: root.is-active;
                has-selection: root.has-selection;
                single-selection: root.single-selection;
                selection-is-dir: root.selection-is-dir;
                clipboard-has-items: root.clipboard-has-items;
                selection-in-trash: root.selection-in-trash;
                row-h: parent.list-row-h;
                icon-size: parent.list-icon;
            }
            if Settings.view-mode == AppViewMode.gallery: FileGridView {
                width: 100%; height: 100%;
                rows: parent.visible-rows;
                showing-search: root.showing-search;
                is-active-pane: root.is-active;
                has-selection: root.has-selection;
                single-selection: root.single-selection;
                selection-is-dir: root.selection-is-dir;
                clipboard-has-items: root.clipboard-has-items;
                selection-in-trash: root.selection-in-trash;
                tile-w: parent.gallery-tile-w;
                tile-h: parent.gallery-tile-h;
                icon-size: parent.gallery-icon;
            }
        }
    }
}
