import { ColorPalette, Translations, Callabler, DialogState } from "../globals.slint";
import { Button, LineEdit, CheckBox, ListView, ComboBox } from "std-widgets.slint";
import { Icon } from "../icons.slint";
import { OpenWithApp } from "structs.slint";

component DialogShell inherits Rectangle {
    in property <length> dialog-width: 360px;
    in property <length> dialog-height: 160px;

    callback rejected();

    background: #00000088;

    scrim := TouchArea {
        clicked => { root.rejected(); }
        scroll-event(event) => { accept }
    }

    Rectangle {
        x: (parent.width - root.dialog-width) / 2;
        y: (parent.height - root.dialog-height) / 2;
        width: root.dialog-width;
        height: root.dialog-height;
        background: ColorPalette.bg-panel;
        border-color: ColorPalette.border-subtle;
        border-width: 1px;
        border-radius: 10px;
        drop-shadow-blur: 24px;
        drop-shadow-color: #00000080;

        // Catch clicks inside so they don't propagate to the scrim.
        TouchArea {}

        @children
    }
}

export component DeleteConfirmDialog inherits DialogShell {
    dialog-width: 420px;
    dialog-height: 180px;
    rejected => { DialogState.delete-confirm-open = false; }

    VerticalLayout {
        padding: 20px;
        spacing: 14px;

        Text {
            text: Translations.dlg-delete-title;
            color: ColorPalette.text-primary;
            font-size: 15px;
            font-weight: 700;
        }

        Text {
            text: Translations.dlg-delete-body + " (" + DialogState.delete-target-count + " items)";
            color: ColorPalette.text-secondary;
            font-size: 13px;
            wrap: word-wrap;
            vertical-stretch: 1;
        }

        HorizontalLayout {
            spacing: 8px;
            alignment: end;

            Button {
                text: Translations.dlg-cancel;
                clicked => { DialogState.delete-confirm-open = false; }
            }
            Button {
                text: Translations.dlg-delete-confirm;
                primary: true;
                clicked => {
                    DialogState.delete-confirm-open = false;
                    Callabler.delete-confirmed();
                }
            }
        }
    }
}

export component RemoteMountDialog inherits DialogShell {
    dialog-width: 460px;
    dialog-height: 230px;
    rejected => {
        DialogState.remote-mount-open = false;
        Callabler.remote-mount-cancelled();
    }

    init => {
        edit.text = "";
        edit.focus();
    }

    VerticalLayout {
        padding: 20px;
        spacing: 12px;

        Text {
            text: Translations.dlg-remote-title;
            color: ColorPalette.text-primary;
            font-size: 15px;
            font-weight: 700;
        }

        Text {
            text: Translations.dlg-remote-body + " " + DialogState.remote-host;
            color: ColorPalette.text-secondary;
            font-size: 12px;
            wrap: word-wrap;
            overflow: elide;
        }

        Text {
            text: Translations.dlg-remote-error;
            color: #e74c3c;
            font-size: 12px;
            wrap: word-wrap;
            visible: DialogState.remote-error;
        }

        edit := LineEdit {
            input-type: InputType.password;
            placeholder-text: "Password";
            accepted(t) => {
                DialogState.remote-mount-open = false;
                Callabler.remote-mount-confirmed(t);
            }
        }

        Rectangle { vertical-stretch: 1; }

        HorizontalLayout {
            spacing: 8px;
            alignment: end;

            Button {
                text: Translations.dlg-cancel;
                clicked => {
                    DialogState.remote-mount-open = false;
                    Callabler.remote-mount-cancelled();
                }
            }
            Button {
                text: Translations.dlg-remote-confirm;
                primary: true;
                clicked => {
                    DialogState.remote-mount-open = false;
                    Callabler.remote-mount-confirmed(edit.text);
                }
            }
        }
    }
}

